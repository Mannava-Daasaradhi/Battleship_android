{
  "rules": {
    "roomCodes": {
      ".read": "auth != null",
      "$roomCode": {
        ".write": "auth != null && !data.exists()"
      }
    },
    "games": {
      "$gameId": {
        ".read": "auth != null && (\n          data.child('meta/hostUid').val() === auth.uid ||\n          data.child('meta/guestUid').val() === auth.uid\n        )",
        "meta": {
          ".write": "auth != null && (\n            !data.exists() ||\n            data.child('hostUid').val() === auth.uid ||\n            data.child('guestUid').val() === auth.uid ||\n            (\n              data.child('guestUid').val() === null &&\n              newData.child('guestUid').val() === auth.uid\n            )\n          )"
        },
        "players": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "boards": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid && !data.exists()",
            ".read": "auth != null && (\n              auth.uid === $uid ||\n              root.child('games').child($gameId).child('meta/status').val() === 'finished'\n            )"
          }
        },
        "shots": {
          "$shooterUid": {
            ".write": "auth != null && auth.uid === $shooterUid",
            "$shotPushKey": {
              ".write": "auth != null && auth.uid === $shooterUid && (\n                !data.exists() ||\n                (newData.child('timestamp').val() - data.child('timestamp').val() > 500)\n              )",
              "result": {
                ".write": "auth != null &&\n                  auth.uid !== $shooterUid && (\n                    root.child('games').child($gameId).child('meta/hostUid').val() === auth.uid ||\n                    root.child('games').child($gameId).child('meta/guestUid').val() === auth.uid\n                  ) && !data.exists()"
              },
              "shipId": {
                ".write": "auth != null && (\n                    root.child('games').child($gameId).child('meta/hostUid').val() === auth.uid ||\n                    root.child('games').child($gameId).child('meta/guestUid').val() === auth.uid\n                  ) && !data.exists()"
              }
            }
          }
        },
        "chat": {
          "$messageId": {
            ".write": "auth != null && (\n              root.child('games').child($gameId).child('meta/hostUid').val() === auth.uid ||\n              root.child('games').child($gameId).child('meta/guestUid').val() === auth.uid\n            ) && newData.child('text').val().length <= 50"
          }
        }
      }
    }
  }
}