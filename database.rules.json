{
  "rules": {

    "roomCodes": {
      ".read":  "auth != null",
      "$roomCode": {
        ".write": "auth != null && !data.exists()"
      }
    },

    "games": {
      "$gameId": {
        ".read": "auth != null && (
          data.child('meta/hostUid').val() === auth.uid ||
          data.child('meta/guestUid').val() === auth.uid
        )",

        "meta": {
          ".write": "auth != null && (
            !data.exists() ||
            data.child('hostUid').val() === auth.uid ||
            data.child('guestUid').val() === auth.uid ||
            (
              data.child('guestUid').val() === null &&
              newData.child('guestUid').val() === auth.uid
            )
          )"
        },

        "players": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },

        "boards": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid && !data.exists()",
            ".read":  "auth != null && (
              auth.uid === $uid ||
              root.child('games').child($gameId).child('meta/status').val() === 'finished'
            )"
          }
        },

        "shots": {
          "$shooterUid": {
            ".write": "auth != null && auth.uid === $shooterUid",
            "$shotPushKey": {
              ".write": "auth != null && auth.uid === $shooterUid && (
                !data.exists() ||
                (newData.child('timestamp').val() - data.child('timestamp').val() > 500)
              )",
              "result": {
                ".write": "auth != null &&
                  auth.uid !== $shooterUid && (
                    root.child('games').child($gameId).child('meta/hostUid').val() === auth.uid ||
                    root.child('games').child($gameId).child('meta/guestUid').val() === auth.uid
                  ) && !data.exists()"
              }
            }
          }
        },

        "chat": {
          "$messageId": {
            ".write": "auth != null && (
              root.child('games').child($gameId).child('meta/hostUid').val() === auth.uid ||
              root.child('games').child($gameId).child('meta/guestUid').val() === auth.uid
            ) && newData.child('text').val().length <= 50"
          }
        }
      }
    }

  }
}